--- !u!114 &2581720134056972615
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1741298960344510401}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "1. \uAC8C\uC784 \uC2DC\uC791 \uD6C4 30~60\uCD08 \uC0AC\uC774 \uB79C\uB364\uD55C
    \uC2DC\uAC04\uC774 \uC9C0\uB098\uBA74\n\uB9F5\uC774 <color=#4c8eaa>\uC554\uC804</color>\uB429\uB2C8\uB2E4.\n\n2.
    \uC554\uC804 \uD6C4\uC5D0\uB294 \uB2E4\uB978 \uD50C\uB808\uC774\uC5B4\uC758 \uC774\uB984\uC744
    \uBCFC \uC218 \uC5C6\uACE0,\n<color=#4c8eaa>\uD751\uBC31</color>\uC73C\uB85C
    \uC2DC\uC57C\uAC00 \uBCC0\uD558\uBA70 \uBC0F \uBC94\uC704 \uC5ED\uC2DC \uC81C\uD55C\uB429\uB2C8\uB2E4.\n\n3.
    \uB9F5\uC744 \uB3CC\uC544\uB2E4\uB2C8\uBA70 \uC5F4 \uC218 \uC788\uB294 \uAC00\uAD6C\uB97C
    \uCC3E\uC544 \n\uADF8 \uC548\uC5D0 \uC788\uB294 \uC544\uC774\uD15C\uC744 \uCC3E\uC544\uBCF4\uC138\uC694.\n\n4.
    \uAC00\uAD6C\uC5D0\uC11C \uC5BB\uC744 \uC218 \uC788\uB294 \uC544\uC774\uD15C\uC740
    \uCD1D 3\uC885\uB958\uB85C \n<color=#4c8eaa>\uD654\uC57D, \uC131\uB0E5, \uC885\uC774</color>\uAC00
    \uC788\uC2B5\uB2C8\uB2E4.\n\n5. 3\uC885\uB958\uC758 \uC544\uC774\uD15C\uC744
    \uD558\uB098\uC529 \uBAA8\uC544 \uC870\uD569\uB300\uC5D0 \uB123\uC73C\uBA74 \n<color=#4c8eaa>\uD3ED\uC8FD</color>
    \uC544\uC774\uD15C\uC744 \uC5BB\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n6.
    \uB2E8, \uC77C\uBC18 \uD50C\uB808\uC774\uC5B4\uC758 \uC778\uBCA4\uD1A0\uB9AC\uB294
    <color=#4c8eaa>1\uCE78</color>\uC73C\uB85C \uC81C\uD55C\uB418\uBA70 \n\uC0B4\uC778\uC790\uC758
    \uACBD\uC6B0\uC5D0\uB294 \uCE7C\uC744 \uB123\uC744 \uC218 \uC788\uAE30\uC5D0
    <color=#4c8eaa>2\uCE78</color>\uC73C\uB85C \uC81C\uD55C\uB429\uB2C8\uB2E4."
